# Launcher Hub Configuration
# Copy this file to .env and customize for your setup

# Steam Deck IP address for deployment (REQUIRED)
# Find this in your Steam Deck's network settings
DECK_IP=192.168.1.100

# SSH user (default is 'deck')
DECK_USER=deck

# Decky plugins directory (default is ~/homebrew/plugins)
DECKY_PLUGIN_DIR=~/homebrew/plugins

# Optional: Privilege escalation password (Ansible pattern)
# ⚠️  SECURITY WARNING: Only use this on development Steam Decks!
# This enables automated deployment following Ansible best practices
# Uncomment and set your sudo password:
# ANSIBLE_BECOME_PASSWORD=your_sudo_password
# Or use Decky-specific naming:
# DECK_BECOME_PASSWORD=your_sudo_password

# For better security, consider using:
# 1. sshpass tool (install: apt-get install sshpass)
# 2. Ansible vault for encrypted passwords
# 3. NOPASSWD sudo for development (less secure)