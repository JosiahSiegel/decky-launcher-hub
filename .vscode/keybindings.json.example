// Keyboard shortcuts for common tasks
// To use: Copy this file to .vscode/keybindings.json or add to your user keybindings
// The personal keybindings.json file is ignored by git
[
  {
    "key": "ctrl+shift+d",
    "command": "workbench.action.tasks.runTask",
    "args": "🧹 Clean, Build & Deploy"
  },
  {
    "key": "ctrl+shift+b",
    "command": "workbench.action.tasks.runTask",
    "args": "📦 Build & Deploy"
  },
  {
    "key": "ctrl+shift+f",
    "command": "workbench.action.tasks.runTask",
    "args": "✅ Fix Code Issues"
  },
  {
    "key": "ctrl+shift+w",
    "command": "workbench.action.tasks.runTask",
    "args": "👀 Watch Mode"
  }
]