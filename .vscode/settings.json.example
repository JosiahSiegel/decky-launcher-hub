{
  // Copy this file to .vscode/settings.json and customize as needed
  
  // Editor settings
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit"
  },
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  
  // File associations
  "files.associations": {
    "*.tsx": "typescriptreact",
    "*.jsx": "javascriptreact",
    "*.mjs": "javascript",
    "*.cjs": "javascript"
  },
  
  // TypeScript settings
  "typescript.tsdk": "node_modules/typescript/lib",
  "typescript.enablePromptUseWorkspaceTsdk": true,
  
  // ESLint settings
  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact"
  ],
  "eslint.options": {
    "overrideConfigFile": "config/eslint.config.mjs"
  },
  
  // Prettier settings
  "prettier.configPath": "config/prettier.config.json",
  
  // Python settings
  "[python]": {
    "editor.defaultFormatter": "ms-python.black-formatter",
    "editor.formatOnSave": true
  },
  
  // Task settings - Disable scanning prompts
  "task.problemMatchers.neverPrompt": true,
  
  // Files to exclude from explorer
  "files.exclude": {
    "**/__pycache__": true,
    "**/*.pyc": true,
    "**/node_modules": true,
    "**/dist": false,
    "**/.git": true,
    "**/.DS_Store": true,
    "**/Thumbs.db": true
  },
  
  // Search exclusions
  "search.exclude": {
    "**/node_modules": true,
    "**/dist": true,
    "**/coverage": true,
    "**/*.log": true,
    "package-lock.json": true
  },
  
  // Terminal settings
  "terminal.integrated.defaultProfile.linux": "bash",
  "terminal.integrated.defaultProfile.osx": "zsh",
  "terminal.integrated.defaultProfile.windows": "powershell",
  
  // Git settings
  "git.ignoreLimitWarning": true,
  
  // Recommended extensions reminder
  "extensions.ignoreRecommendations": false
}